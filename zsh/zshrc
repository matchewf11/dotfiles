HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt hist_ignore_dups # ignore saving dup cmds
setopt hist_ignore_space # dont save cmd is starts w/ space
setopt append_history
setopt share_history

source <(fzf --zsh)
bindkey -v

autoload -Uz compinit && compinit

ff() {
	firefox --new-tab "$@" > /dev/null 2>&1 & disown
}

alias email="ff https://mail.google.com/mail/u/0/#inbox"
alias canvas="ff https://canvas.uw.edu/"
alias github="ff https://github.com/"

alias vi='nvim'

# (learn how to use this)
alias ls='eza'
alias grep='rg'
alias top='htop'
alias cat='bat'
alias find='fd'

cdf() {
  local dir
  dir=$(fd --type d --hidden --follow . | fzf) || return  # fuzzy find a directory
  if [[ -n "$dir" ]]; then
    cd "$dir" || echo "Failed to cd into $dir"
  fi
}

fe() {
  local file
  file=$(fzf) || return   # fuzzy find a file
  if [[ -n "$file" ]]; then
    vi "$file"
  fi
}

# cd ... (look into other zsh specific stuff)
up() {
  local n=${1:-1}
  for ((i = 0; i < n; i++)); do
    cd ..
  done
}

export STARSHIP_CONFIG=~/.config/starship/starship.toml

ZSH_PLUGIN_PATH=/usr/share/zsh/plugins
source $ZSH_PLUGIN_PATH/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source $ZSH_PLUGIN_PATH/zsh-history-substring-search/zsh-history-substring-search.zsh

bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '^P'   history-substring-search-up
bindkey '^N'   history-substring-search-down

