set number relativenumber
set smartindent autoindent
set scrolloff=10 laststatus=2 showtabline=2 signcolumn=yes
set undofile undodir=~/.vim/undo noswapfile updatetime=100 hidden
set completeopt=noinsert,menuone,noselect,fuzzy
set timeoutlen=300 mouse=a incsearch
set expandtab tabstop=4 shiftwidth=4 softtabstop=4
set path+=** tags=./tags;,tags
set statusline=%f\ %m%r%h%w%y%q%=%l/%L:%c%V

let mapleader = " "
nnoremap <leader>e :Ex<CR>
nnoremap <leader>t :tabnew<CR>
nnoremap <leader>x :tabclose<CR>
nnoremap <leader>c :!ctags -R .<CR>
nnoremap <leader>p "+p
nnoremap <leader>d "_d
vnoremap <leader>d "_d
nnoremap <leader>y "+y
vnoremap <leader>y "+y

function! LspDiagStatus() abort
    let l:counts = lsp#get_buffer_diagnostics_counts()
    let l:err = get(l:counts, 'error', 0)
    let l:warn = get(l:counts, 'warning', 0)
    if l:err == 0 && l:warn == 0
        return 'OK'
    endif
    let l:parts = []
    if l:err > 0
        call add(l:parts, 'E:' . l:err)
    endif
    if l:warn > 0
        call add(l:parts, 'W:' . l:warn)
    endif
    return join(l:parts, ', ')
endfunction

augroup delete_trailing_whitespace
  autocmd!
  autocmd BufWritePre * %s/\s\+$//e
augroup END

if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
endif

call plug#begin()
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-surround'
Plug 'bluz71/vim-moonfly-colors'
Plug 'prabirshrestha/vim-lsp'
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'
call plug#end()

if executable('rust-analyzer')
    au User lsp_setup call lsp#register_server({
        \ 'name': 'rust-analyzer',
        \ 'cmd': {server_info->['rust-analyzer']},
        \ 'allowlist': ['rust'],
        \ })
endif

let g:lsp_format_sync_timeout = 1000
let g:lsp_semantic_enabled = 1
let g:lsp_document_highlight_enabled = 0
let g:lsp_diagnostics_virtual_text_enabled = 0
let g:lsp_diagnostics_echo_cursor = 1

function! s:on_lsp_buffer_enabled() abort
    setlocal statusline=%f\ %m%r%h%w%y%q%=%{LspDiagStatus()}\ %l/%L:%c%V
    setlocal omnifunc=lsp#complete
    if exists('+tagfunc') | setlocal tagfunc=lsp#tagfunc | endif
    autocmd! BufWritePre *.rs call execute('LspDocumentFormatSync')

    nmap <buffer> grd <plug>(lsp-definition)
    nmap <buffer> grD :LspDeclaration<CR>
    nmap <buffer> grs <plug>(lsp-document-symbol-search)
    nmap <buffer> grS <plug>(lsp-workspace-symbol-search)
    nmap <buffer> grr <plug>(lsp-references)
    nmap <buffer> gri <plug>(lsp-implementation)
    nmap <buffer> grt <plug>(lsp-type-definition)
    nmap <buffer> grn <plug>(lsp-rename)
    nmap <buffer> [d <plug>(lsp-previous-diagnostic)
    nmap <buffer> ]d <plug>(lsp-next-diagnostic)
    nmap <buffer> K <plug>(lsp-hover)
    nmap <buffer> gra :LspCodeAction<CR>
    nnoremap <buffer> <expr><c-f> lsp#scroll(+4)
    nnoremap <buffer> <expr><c-d> lsp#scroll(-4)
    nmap <buffer> <leader>d :LspDocumentDiagnostics<CR>
endfunction

augroup lsp_install
    au!
    autocmd User lsp_buffer_enabled call s:on_lsp_buffer_enabled()
augroup END

silent! colorscheme moonfly

nnoremap <leader>sF :GFiles<CR>
nnoremap <leader>sf :Files<CR>
nnoremap <leader>sb :Buffers<CR>
nnoremap <leader>sl :BLines<CR>
nnoremap <leader>sL :Lines<CR>

" :Ag [PATTERN] 	ag search result (ALT-A to select all, ALT-D to deselect all)
" :Rg [PATTERN] 	rg search result (ALT-A to select all, ALT-D to deselect all)
" :RG [PATTERN] 	rg search result; relaunch ripgrep on every keystroke
" :Tags [PREFIX] 	Tags in the project (ctags -R)
" :BTags [QUERY] 	Tags in the current buffer
" :History 	v:oldfiles and open buffers
" :History: 	Command history
" :History/ 	Search history
" :Snippets 	Snippets (UltiSnips)
" :Commits [LOG_OPTS] 	Git commits (requires fugitive.vim)
" :BCommits [LOG_OPTS] 	Git commits for the current buffer; visual-select lines to track changes in the range
