augroup delete_trailing_whitespace
  autocmd!
  autocmd BufWritePre * %s/\s\+$//e
augroup END

let mapleader = " "
nnoremap <leader>e :Ex<CR>
nnoremap <leader>t :tabnew<CR>
nnoremap <leader>x :tabclose<CR>
nnoremap <leader>d "_d
vnoremap <leader>d "_d

nnoremap [b :bn<CR>
nnoremap ]b :bp<CR>
nnoremap [B :bfirst<CR>
nnoremap ]B :blast<CR>

nnoremap [t :tabnext<CR>
nnoremap ]t :tabprev<CR>
nnoremap [T :tabfirst<CR>
nnoremap ]T :tablast<CR>

vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv
nnoremap gd :ALEDetail<CR>
nnoremap grt :ALEGoToTypeDefinition<CR>
nnoremap grd :ALEGoToDefinition<CR>
nnoremap grr :ALEFindReferences<CR>
nnoremap grn :ALERename<CR>
nnoremap gra :ALECodeAction<CR>
nnoremap gri :ALECodeImplementation<CR>
nnoremap K :ALEHover<CR>
nnoremap <leader>f :ALEFix<CR>

