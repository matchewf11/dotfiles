let g:ale_virtualtext_cursor = 'disabled'
call plug#begin()
Plug 'zenbones-theme/zenbones.nvim'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-surround'
Plug 'dense-analysis/ale'
call plug#end()

silent! colorscheme rosebones

