let g:netrw_banner = 0

let mapleader = " "

set number
set relativenumber

set scrolloff=10

set splitright
set splitbelow

set noswapfile
set undofile
set updatetime=100

colorscheme slate
set termguicolors

set laststatus=2
set showtabline=2

set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4

set smartindent
set autoindent
filetype plugin indent on
syntax on

set mouse=a

nnoremap <leader>e :Ex<CR>

nnoremap <leader>t :tabnew<CR>
nnoremap <leader>x :tabclose<CR>

nnoremap <leader>d "_d
vnoremap <leader>d "_d

vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv

augroup delete_trailing_whitespace
  autocmd!
  autocmd BufWritePre * %s/\s\+$//e
augroup END

augroup rust_setup
    autocmd!
    autocmd FileType rust setlocal expandtab shiftwidth=4 softtabstop=4
    autocmd FileType rust nnoremap <leader>rb :!cargo build<CR>
    autocmd FileType rust nnoremap <leader>rr :!cargo run<CR>
    autocmd FileType rust nnoremap <leader>rt :!cargo test<CR>
    autocmd FileType rust nnoremap <leader>rc :!cargo check<CR>
augroup END
