" install vim-plug
" curl -fLo ~/.vim/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
" be sure to install rust-analyzer!

let g:netrw_banner = 0

let mapleader = " "

set number
set relativenumber
set signcolumn=yes

set scrolloff=10

set mouse=a

set timeoutlen=300

set splitright
set splitbelow

set noswapfile
set undofile
set undodir=~/.vim/undo
set updatetime=100

colorscheme slate
set termguicolors

set laststatus=2
set showtabline=2

set expandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4

set smartindent
set autoindent

nnoremap <leader>e :Ex<CR>

nnoremap <leader>t :tabnew<CR>
nnoremap <leader>x :tabclose<CR>
nnoremap <leader>n :bn<CR>
nnoremap <leader>p :bp<CR>

nnoremap <leader>d "_d
vnoremap <leader>d "_d

vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv

nnoremap gd :ALEDetail<CR>
nnoremap grd :ALEGoToDefinition<CR>
nnoremap grr :ALEFindReferences<CR>
nnoremap grn :ALERename<CR>
nnoremap gra :ALECodeAction<CR>
nnoremap K :ALEHover<CR>
nnoremap <leader>f :ALEFix<CR>


let g:ale_linters = {'rust': ['rust_analyzer']}
let g:ale_fixers = {'rust': ['rustfmt']}
let g:ale_virtualtext_cursor = 'disabled'
" let g:ale_sign_colomn_always = v:true

" use this with <C-x><C-o> in Insert mode
set omnifunc=ale#completion#OmniFunc

call plug#begin()

" gcc to comment line
" gc <ap> or something similar
" gc in visual mode to toggle comment
" gc is a text item
" gcgc toggle comments
Plug 'tpope/vim-commentary'

" cs"'
" cs'<q>
" cst"
" ds"
" ysiw] ([ to give space)
" yssb / yss) to surround line
" VS<p>
" (repeatable with repeat.vim)
Plug 'tpope/vim-surround'

" navigat hunks
" operator for acting on hunks
" preview changes in another buffer
" show chnates in diff mode
" statusline stuff
Plug 'mhinz/vim-signify'

Plug 'dense-analysis/ale'

